NODE_ENV=development
PORT=5000
HOST=0.0.0.0
MONGO_URI=mongodb://127.0.0.1:27017/storesync
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
ADMIN_REGISTRATION_SECRET=replace_with_admin_bootstrap_secret
SUPER_ADMIN_REGISTRATION_SECRET=replace_with_super_admin_bootstrap_secret
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
HTTP_ACCESS_LOGS=true

# Traffic protection
MAX_IN_FLIGHT_REQUESTS=1000
REQUEST_RATE_LIMIT_WINDOW_MS=60000
REQUEST_RATE_LIMIT_MAX_PER_IP=10000
REQUEST_RATE_LIMIT_MAX_GLOBAL=120000
REQUEST_RATE_LIMIT_CLEANUP_INTERVAL=500

# Public response cache
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_TTL_SECONDS=15
RESPONSE_CACHE_MAX_ENTRIES=500

# MongoDB connection pool tuning
DB_MAX_POOL_SIZE=100
DB_MIN_POOL_SIZE=5
DB_MAX_CONNECTING=8
DB_SERVER_SELECTION_TIMEOUT_MS=10000
DB_SOCKET_TIMEOUT_MS=45000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Leave unset for the default behavior: enabled in local development, disabled in production.
ALLOW_LOCAL_ASSET_STORAGE=
# Optional base URL when using local asset storage
ASSET_BASE_URL=http://localhost:5000

# Optional Firebase Cloud Messaging credentials
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_PATH=
